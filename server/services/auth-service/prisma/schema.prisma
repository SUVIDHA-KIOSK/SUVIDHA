// Prisma schema for Auth Service (NeonDB/PostgreSQL)
// https://pris.ly/d/prisma-schema

datasource db {
	provider = "postgresql"
}

generator client {
	provider = "prisma-client-js"
}

model User {
	id         String    @id @default(uuid())
	status     String    @db.VarChar(20)
	created_at DateTime  @default(now())
	updated_at DateTime  @updatedAt
	authIdentities AuthIdentity[]
	sessions   UserSession[]
	profile    Profile?
	contacts   Contact[]
}

model AuthIdentity {
	id         String   @id @default(uuid())
	user       User    @relation(fields: [user_id], references: [id])
	user_id    String
	provider   String  @db.VarChar(32)
	identfier String  @unique @db.VarChar(128)
	createid_at DateTime @default(now())
}

model UserSession {
	id            String   @id @default(uuid())
	user          User     @relation(fields: [user_id], references: [id])
	user_id       String
	refresh_token String   @db.VarChar(255)
	expires_at    DateTime
	is_revoked    Boolean  @default(false)
}

model Profile {
	id         String   @id @default(uuid())
	user       User     @relation(fields: [user_id], references: [id])
	user_id    String   @unique
	name       String   @db.VarChar(128)
	dob        DateTime?
	gender     String?  @db.VarChar(16)
	updated_at DateTime @updatedAt
}

model Contact {
	id           String   @id @default(uuid())
	user         User     @relation(fields: [user_id], references: [id])
	user_id      String
	phone        String   @unique @db.VarChar(16)
	email        String   @unique @db.VarChar(128)
	address_line String?
	city         String?  @db.VarChar(64)
	state        String?  @db.VarChar(64)
	pincode      String?  @db.VarChar(16)
	updated_at   DateTime @updatedAt
}
